{
    "$schema": "https://raw.githubusercontent.com/ManualForArchipelago/Manual/main/schemas/Manual.options.schema.json",
    "_comment": "Add a _ before an option name to comment it out and it wont be added to the apworld",
    "core": {
        "death_link": {
            "default": false
        }
    },
    "user": {
        "choose_skill_amount":{
            "type": "Range",
            "description": [
                "How many Choose Skill items are in the item pool. Min: 0, Default: 4, Max: 10"
            ],
            "range_start": 0,
            "default": 4,
            "range_end": 10,
            "group": "Useful Items"
        },
        "choose_passive_amount":{
            "type": "Range",
            "description": [
                "How many Choose Passive items are in the item pool. Min: 0, Default: 4, Max: 10"
            ],
            "range_start": 0,
            "default": 4,
            "range_end": 10,
            "group": "Useful Items"
        },
        "uncommon_items_amount":{
            "type": "Range",
            "description": [
                "How many Obtain Random Uncommon Items are in the item pool. Min: 0, Default: 10, Max: 20"
            ],
            "range_start": 0,
            "default": 10,
            "range_end": 20,
            "group": "Useful Items"
        },
        "rare_items_amount":{
            "type": "Range",
            "description": [
                "How many Obtain Random Rare Items are in the item pool. Min: 0, Default: 5, Max: 10"
            ],
            "range_start": 0,
            "default": 5,
            "range_end": 10,
            "group": "Useful Items"
        },
        "very_rare_items_amount":{
            "type": "Range",
            "description": [
                "How many Obtain Random Very Rare Items are in the item pool. Min: 0, Default: 3, Max: 5"
            ],
            "range_start": 0,
            "default": 3,
            "range_end": 5,
            "group": "Useful Items"
        }
    }

}